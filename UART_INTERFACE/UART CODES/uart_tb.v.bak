`timescale 1ns/1ps
module uart_tb;
 
    // ----------------------------------------------------------------
    // Clock and signals
    // ----------------------------------------------------------------
    reg clk = 1'b0;
    always #5 clk = ~clk;    // 100 MHz clock, 10 ns period
 
    reg        rst;
    reg        wr_en;
    reg  [7:0] data_in;
    wire [7:0] data_out;
    wire       tx;
    wire       irq;
 
    // ----------------------------------------------------------------
    // Scoreboard
    // ----------------------------------------------------------------
    reg  [7:0] sent_q [0:4];
    reg  [2:0] sent_idx;
    reg  [2:0] recv_idx;
    integer    pass_cnt;
    integer    fail_cnt;
 
    // ----------------------------------------------------------------
    // DUT
    // ----------------------------------------------------------------
    uart_top uut (
        .clk      (clk),
        .rst      (rst),
        .wr_en    (wr_en),
        .data_in  (data_in),
        .data_out (data_out),
        .tx       (tx),
        .irq      (irq)
    );
 
    // ----------------------------------------------------------------
    // $monitor ? prints to TCL console on ANY signal change
    // ----------------------------------------------------------------
    initial begin
        $display("==================================================");
        $display("   UART LOOPBACK SIMULATION ? ModelSim 2020.1");
        $display("   Clock : 100 MHz | Baud tick : every 16 clocks");
        $display("   Frame : 8-N-1  | Loopback  : tx -> rx");
        $display("==================================================");
        $monitor("[MON] %0t ps | clk=%b rst=%b wr_en=%b tx=%b irq=%b data_out=8'h%02h",
                 $time, clk, rst, wr_en, tx, irq, data_out);
    end
 
    // ----------------------------------------------------------------
    // Task: send ? pushes one byte into TX FIFO
    // ----------------------------------------------------------------
    task send;
        input [7:0] byte_val;
        begin
            @(posedge clk); #1;
            wr_en   = 1'b1;
            data_in = byte_val;
            @(posedge clk); #1;
            wr_en   = 1'b0;
            data_in = 8'h00;
 
            sent_q[sent_idx] = byte_val;
            sent_idx         = sent_idx + 3'd1;
 
            $display("[TX ] Byte #%0d sent     -> 8'h%02h  (%0d decimal)",
                     sent_idx, byte_val, byte_val);
        end
    endtask
 
    // ----------------------------------------------------------------
    // RX monitor ? fires on every rx_valid pulse
    // ----------------------------------------------------------------
    always @(posedge clk) begin
        if (uut.rxu.valid) begin
            $display("--------------------------------------------------");
            $display("[RX ] Byte #%0d received -> 8'h%02h  (%0d decimal)",
                     recv_idx + 1, uut.rxu.data, uut.rxu.data);
            $display("      Expected           -> 8'h%02h  (%0d decimal)",
                     sent_q[recv_idx], sent_q[recv_idx]);
            $display("      data_out port      -> 8'h%02h", data_out);
 
            if (uut.rxu.data === sent_q[recv_idx]) begin
                $display("      CHECK              -> PASS");
                pass_cnt = pass_cnt + 1;
            end else begin
                $display("      CHECK              -> FAIL  *** MISMATCH ***");
                fail_cnt = fail_cnt + 1;
            end
            $display("--------------------------------------------------");
            recv_idx = recv_idx + 3'd1;
        end
    end
 
    // ----------------------------------------------------------------
    // Stimulus
    // ----------------------------------------------------------------
    initial begin
        // Init scoreboard
        sent_idx = 3'd0;
        recv_idx = 3'd0;
        pass_cnt = 0;
        fail_cnt = 0;
 
        // Apply reset
        rst     = 1'b1;
        wr_en   = 1'b0;
        data_in = 8'h00;
        $display("[RST] Reset asserted at t=%0t ps", $time);
        repeat (10) @(posedge clk);
        rst = 1'b0;
        repeat (2) @(posedge clk);
        $display("[RST] Reset released  at t=%0t ps", $time);
        $display("--------------------------------------------------");
 
        // Send 5 test bytes
        // Frame = 10 bits * 16 ticks * 10 ns = 1600 ns per byte
        send(8'h3C);   //  60 dec
        send(8'hA5);   // 165 dec
        send(8'h5A);   //  90 dec
        send(8'hFF);   // 255 dec
        send(8'h81);   // 129 dec
 
        $display("--------------------------------------------------");
        $display("[INF] 5 bytes loaded into TX FIFO");
        $display("[INF] Awaiting loopback reception ...");
        $display("[INF] Each frame = 1600 ns  |  5 frames = 8000 ns");
        $display("--------------------------------------------------");
 
        // Wait for all 5 bytes to transmit and loop back
        // 5 * 1600 ns = 8000 ns, add generous margin
        #50000;
 
        // ---- Final summary ----
        $display("==================================================");
        $display("  SIMULATION SUMMARY");
        $display("  Bytes sent     : %0d", sent_idx);
        $display("  Bytes received : %0d", recv_idx);
        $display("  PASS           : %0d", pass_cnt);
        $display("  FAIL           : %0d", fail_cnt);
        $display("--------------------------------------------------");
        if (pass_cnt == 5 && fail_cnt == 0)
            $display("  RESULT  :  ALL 5 BYTES PASSED  (LOOPBACK OK)");
        else
            $display("  RESULT  :  ERRORS DETECTED ? check waveform");
        $display("==================================================");
        $finish;
    end
 
endmodule
