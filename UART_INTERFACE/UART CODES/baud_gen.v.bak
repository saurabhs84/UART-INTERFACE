module baud_gen (
    input  clk,
    input  rst,
    output reg tick
);
    reg [3:0] count;
 
    always @(posedge clk or posedge rst) begin
        if (rst) begin
            count <= 4'd0;
            tick  <= 1'b0;
        end else if (count == 4'd15) begin
            count <= 4'd0;
            tick  <= 1'b1;
        end else begin
            count <= count + 4'd1;
            tick  <= 1'b0;
        end
    end
endmodule
 
// ------------------------------------------------------------
// MODULE 2: sync_fifo
// Synchronous FIFO depth=8, width=8
// dout valid ONE cycle after rd_en
// ------------------------------------------------------------
module sync_fifo (
    input            clk,
    input            rst,
    input            wr_en,
    input            rd_en,
    input      [7:0] din,
    output reg [7:0] dout,
    output           full,
    output           empty
);
    reg [7:0] mem  [0:7];
    reg [2:0] wptr;
    reg [2:0] rptr;
    reg [3:0] cnt;
 
    assign full  = (cnt == 4'd8);
    assign empty = (cnt == 4'd0);
 
    always @(posedge clk or posedge rst) begin
        if (rst) begin
            wptr <= 3'd0;
            rptr <= 3'd0;
            cnt  <= 4'd0;
            dout <= 8'h00;
        end else begin
            if (wr_en && !full) begin
                mem[wptr] <= din;
                wptr      <= wptr + 3'd1;
            end
            if (rd_en && !empty) begin
                dout <= mem[rptr];
                rptr <= rptr + 3'd1;
            end
            case ({(wr_en && !full), (rd_en && !empty)})
                2'b10:   cnt <= cnt + 4'd1;
                2'b01:   cnt <= cnt - 4'd1;
                default: cnt <= cnt;
            endcase
        end
    end
endmodule
