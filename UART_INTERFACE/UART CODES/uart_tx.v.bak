module uart_tx (
    input            clk,
    input            rst,
    input            tick,
    input      [7:0] fifo_dout,   // registered FIFO output
    input            fifo_empty,
    output reg       fifo_rd_en,  // pop signal to FIFO
    output reg       tx,
    output           busy         // high when not IDLE
);
    localparam IDLE = 2'd0,
               LOAD = 2'd1,
               SEND = 2'd2;
 
    reg [1:0]  state;
    reg [9:0]  shift_reg;   // {STOP, D7..D0, START=0} ? 10 bits
    reg [3:0]  bit_cnt;     // counts 0..8 (9 bits after start bit)
 
    assign busy = (state != IDLE);
 
    always @(posedge clk or posedge rst) begin
        if (rst) begin
            state      <= IDLE;
            tx         <= 1'b1;
            fifo_rd_en <= 1'b0;
            shift_reg  <= 10'h3FF;
            bit_cnt    <= 4'd0;
        end else begin
            fifo_rd_en <= 1'b0;   // default: deassert
 
            case (state)
                // ---- Wait for data in FIFO ----
                IDLE: begin
                    tx <= 1'b1;   // idle line HIGH
                    if (!fifo_empty) begin
                        fifo_rd_en <= 1'b1;   // pop from FIFO
                        state      <= LOAD;
                    end
                end
 
                // ---- FIFO dout now valid ? latch and start frame ----
                LOAD: begin
                    // Build 10-bit frame: STOP(1) D7..D0 START(0)
                    shift_reg <= {1'b1, fifo_dout, 1'b0};
                    tx        <= 1'b0;   // drive start bit immediately
                    bit_cnt   <= 4'd0;
                    state     <= SEND;
                end
 
                // ---- Shift out bits on each baud tick ----
                SEND: begin
                    if (tick) begin
                        // Output next bit from shift register
                        tx        <= shift_reg[0];
                        shift_reg <= {1'b1, shift_reg[9:1]};
                        bit_cnt   <= bit_cnt + 4'd1;
 
                        if (bit_cnt == 4'd8) begin
                            // bit_cnt==8 means we just shifted the STOP bit
                            state <= IDLE;
                            tx    <= 1'b1;
                        end
                    end
                end
 
                default: state <= IDLE;
            endcase
        end
    end
endmodule
